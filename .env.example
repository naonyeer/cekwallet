# ============================================
#  Etherscan V2 unified API key (WAJIB)
# ============================================
# 1 key untuk 50+ chain via Etherscan V2.
# Daftar gratis di https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_v2_api_key_here

# ============================================
#  CoinGecko (opsional)
# ============================================
# Demo API key — naikkan rate limit native price lookup.
# https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=

# ============================================
#  Tuning
# ============================================
# Jeda antar request ke Etherscan / explorer (detik). Default 0.22 = ~4.5 rps.
ETHERSCAN_RATE_DELAY=0.22

# Timeout HTTP (detik).
HTTP_TIMEOUT=30

# ============================================
#  Legacy explorer API keys (OPSIONAL)
# ============================================
# Untuk chain yang BUTUH PAID PLAN di Etherscan V2 (BSC, Base, Optimism,
# Avalanche) atau yang BELUM ada di V2 (Fantom, Scroll, zkSync, dll),
# isi salah satu di bawah ini untuk meng-enable scan-nya. Kalau kosong,
# chain itu di-skip dengan reason yang jelas.

# --- V2 paid chain (alternatif: pakai key explorer asli) ---
BSCSCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
SNOWTRACE_API_KEY=

# --- Belum/tidak di V2 ---
FTMSCAN_API_KEY=
CRONOSCAN_API_KEY=
NOVA_ARBISCAN_API_KEY=
ZKSYNC_ERA_API_KEY=
ZKEVM_POLYGONSCAN_API_KEY=
SCROLLSCAN_API_KEY=
