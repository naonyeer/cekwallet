# Etherscan V2 unified API key — 1 key untuk 50+ chain.
# Daftar di https://etherscan.io/myapikey lalu paste di sini.
ETHERSCAN_API_KEY=your_etherscan_v2_api_key_here

# Opsional: CoinGecko Demo API key (free, naikkan rate limit dari ~10 ke ~30 rpm).
# Daftar di https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=

# Opsional: jeda antar request ke Etherscan (detik). Default 0.22 = ~4.5 rps,
# di bawah batas free tier 5 rps.
ETHERSCAN_RATE_DELAY=0.22

# Opsional: timeout HTTP (detik).
HTTP_TIMEOUT=30
